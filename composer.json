{
    "name": "nextcloud/imageconverter",
    "description": "Nextcloud app that converts images to JPEG and compresses them toward a target size.",
    "license": "AGPL-3.0-or-later",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "nextcloud/coding-standard": "^1.3",
        "nextcloud/ocp": "dev-stable32"
    },
    "autoload": {
        "psr-4": {
            "OCA\\ImageConverter\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\ImageConverter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "vendor/bin/phpcs -p lib/ tests/Unit/",
        "lint:fix": "vendor/bin/phpcbf lib/ tests/Unit/",
        "analyse": "vendor/bin/phpstan analyse",
        "test:unit": "vendor/bin/phpunit --configuration phpunit.xml --testsuite unit",
        "test:integration": "vendor/bin/phpunit --configuration phpunit.integration.xml --testsuite integration"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
